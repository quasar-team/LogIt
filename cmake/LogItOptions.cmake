set(LOGIT_BACKEND_STDOUTLOG_DEFAULT ON)
set(LOGIT_BACKEND_BOOSTLOG_DEFAULT OFF)
set(LOGIT_BACKEND_UATRACE_DEFAULT OFF)
set(LOGIT_BACKEND_WINDOWS_DEBUGGER_DEFAULT OFF)

if(DEFINED ENV{LOGIT_BACKENDS})
    set(LOGIT_BACKEND_STDOUTLOG_DEFAULT OFF)
    set(LOGIT_BACKEND_BOOSTLOG_DEFAULT OFF)
    set(LOGIT_BACKEND_UATRACE_DEFAULT OFF)
    set(LOGIT_BACKEND_WINDOWS_DEBUGGER_DEFAULT OFF)

    set(LOGIT_BACKENDS_FROM_ENV "$ENV{LOGIT_BACKENDS}")
    foreach(LOGIT_BACKEND_FROM_ENV IN LISTS LOGIT_BACKENDS_FROM_ENV)
        set("${LOGIT_BACKEND_FROM_ENV}_DEFAULT" ON)
    endforeach()
endif()

option(LOGIT_BACKEND_STDOUTLOG "The basic back-end: logs to stdout" ${LOGIT_BACKEND_STDOUTLOG_DEFAULT})
option(LOGIT_BACKEND_BOOSTLOG "Rotating file logger back-end: fixed size on disk based on boost logging library" ${LOGIT_BACKEND_BOOSTLOG_DEFAULT})
option(LOGIT_BACKEND_UATRACE "UnifiedAutomation toolkit logger" ${LOGIT_BACKEND_UATRACE_DEFAULT})
option(LOGIT_BACKEND_WINDOWS_DEBUGGER "Windows debugger logger" ${LOGIT_BACKEND_WINDOWS_DEBUGGER_DEFAULT})
option(LOGIT_BUILD_SHARED_LIB "Build a LogIt shared library if ON (otherwise builds an object library)" OFF)
